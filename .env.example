# LLM 配置（必填）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# NVD API Key（可选，有则提升请求配额）
NVD_API_KEY=

# Tavily 搜索 API Key（可选，不填则使用 DuckDuckGo 备用）
TAVILY_API_KEY=

# http2pcap 服务地址（可选，不填则使用内置 httpx + scapy）
HTTP2PCAP_URL=

# wayback-cve 服务地址（可选，不填则使用内置 httpx + trafilatura）
WAYBACK_URL=

# 目标 IP（PoC 验证发送目标）
TARGET_IP=127.0.0.1

# 输出目录
OUTPUT_DIR=output

# 请求超时（秒）
REQUEST_TIMEOUT=30
