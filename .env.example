# LLM 配置（必填，支持 OpenAI 兼容接口）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://jeniya.top/v1
LLM_MODEL=gpt-4o

# HTTP/HTTPS 代理（可选，国内服务器访问外部 API 需配置）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,<http2pcap-host>,<target-ip>

# NVD API Key（可选，有则提升请求配额）
NVD_API_KEY=

# Tavily 搜索 API Key（可选，不填则使用 DuckDuckGo 备用）
TAVILY_API_KEY=

# http2pcap 服务地址（可选，不填则使用内置 httpx + scapy）
HTTP2PCAP_URL=

# 防火墙/IPS 检测接口（http2pcap 服务启用 check_ips 时使用）
IPS_API_URL=

# wayback-cve 服务地址（可选，不填则使用内置 httpx + trafilatura）
WAYBACK_URL=

# 目标 IP（PoC 验证发送目标）
TARGET_IP=127.0.0.1

# 本地 PoC 知识库目录（含 trickest/cve submodule 和 custom/ 自定义 PoC）
POC_KB_DIR=poc_kb

# 输出目录
OUTPUT_DIR=output

# 请求超时（秒）
REQUEST_TIMEOUT=30
