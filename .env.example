# LLM 配置（必填，支持 OpenAI 兼容接口）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://jeniya.top/v1
LLM_MODEL=gpt-4o

# Agent LLM（可选）
# false 时 agent 使用确定性规则；true 时 Trigger/Critic/Environment 优先调用大模型。
# AGENT_LLM_MODEL 留空会复用 LLM_MODEL。
AGENT_LLM_ENABLED=false
AGENT_LLM_MODEL=

# HTTP/HTTPS 代理（可选，国内服务器访问外部 API 需配置）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1,<http2pcap-host>,<target-ip>

# NVD API Key（可选，有则提升请求配额）
NVD_API_KEY=

# Tavily 搜索 API Key（可选，不填则使用 DuckDuckGo 备用）
TAVILY_API_KEY=

# http2pcap 服务地址（可选，不填则使用内置 httpx + scapy）
HTTP2PCAP_URL=

# 防火墙/IPS 检测接口（http2pcap 服务启用 check_ips 时使用）
IPS_API_URL=

# wayback-cve 服务地址（可选，不填则使用内置 httpx + trafilatura）
WAYBACK_URL=

# 目标 IP（PoC 验证发送目标）
TARGET_IP=127.0.0.1

# 自动攻击环境（Docker/Vulhub）
# false 时只发现和记录环境候选；true 时会对命中的 compose 执行 pull/up -d。
AUTO_ENV_ENABLED=false
VULHUB_DIR=third_party/vulhub
ATTACK_ENV_COMPOSE_FILE=
ATTACK_ENV_TARGET_URL=
CALLBACK_URL=

# 执行策略
# plan_only: 只规划/生成候选，不发包；local_lab: 仅允许本地/私有地址或 allowlist；
# authorized_target: 必须命中 TARGET_ALLOWLIST。
RUN_MODE=plan_only
TARGET_ALLOWLIST=127.0.0.1,localhost
MAX_REQUESTS_PER_CVE=20
MAX_CANDIDATES_PER_CVE=50

# 本地 PoC 知识库目录（含 trickest/cve submodule 和 custom/ 自定义 PoC）
POC_KB_DIR=poc_kb

# 本地 NVD 数据库目录（下载 NVD 年度 JSON Feed 到此目录）
NVD_LOCAL_DIR=poc_kb/nvd

# 输出目录
OUTPUT_DIR=output

# 请求超时（秒）
REQUEST_TIMEOUT=30
